            <div>Status: <span class="status-badge {% if calibration_analysis.status == 'VERIFIED' %}status-verified{% elif calibration_analysis.status == 'CRITICAL' %}status-rejected{% else %}status-provisional{% endif %}">{{ calibration_analysis.status }}</span></div>
            <div>ECE: <strong style="font-size: 1.2rem;">{{ calibration_analysis.ece|round(4) }}</strong></div>
