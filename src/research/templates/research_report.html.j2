    {% if execution_quality %}
    {% set ns.count = ns.count + 1 %}
    <section id="execution-quality">
        <div style="float: right;">
            <span class="badge {% if execution_quality.efficiency_score > 90 %}badge-stable{% elif execution_quality.efficiency_score > 75 %}badge-warning{% else %}badge-critical{% endif %}">
                EFFICIENCY: {{ execution_quality.efficiency_score|round(1) }}%
            </span>
        </div>
        <h2>{{ ns.count }}. Execution Quality & Alpha Decay</h2>
        <div class="score-container">
            <span>Execution Efficiency:</span>
            <div class="progress-bar" role="progressbar" aria-valuenow="{{ execution_quality.efficiency_score }}" aria-valuemin="0" aria-valuemax="100" aria-label="Execution efficiency score: {{ execution_quality.efficiency_score|round(1) }} out of 100">
                <div class="progress-fill {% if execution_quality.efficiency_score < 50 %}fill-low{% elif execution_quality.efficiency_score < 80 %}fill-medium{% else %}fill-high{% endif %}" style="width: {{ execution_quality.efficiency_score }}%;"></div>
            </div>
            <span class="score">{{ execution_quality.efficiency_score|round(1) }}/100</span>
        </div>

        <div class="grid-2">
            <div>
                <table>
                    <thead>
                        <tr>
                            <th scope="col">Metric</th>
                            <th scope="col">Value</th>
                            <th scope="col">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for m in execution_quality.metrics %}
                        <tr>
                            <td>{{ m.name }}</td>
                            <td>{{ m.value }}</td>
                            <td>
                                {% if m.status == 'OK' %}<span class="badge badge-stable">{{ m.status }}</span>
                                {% else %}<span class="badge badge-warning">{{ m.status }}</span>{% endif %}
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            <div class="insight-box" style="display: flex; flex-direction: column; justify-content: center;">
                <strong>Opportunity Cost (Blocked):</strong>
                <span style="font-size: 2rem; color: var(--danger); font-weight: 800;">{{ execution_quality.opportunity_cost }}</span>
                <p style="font-size: 0.9rem; margin-top: 1rem;">
                    This represents the hypothetical PnL from signals that were rejected by risk management filters.
                </p>
                <div style="margin-top: auto; font-size: 0.8rem; opacity: 0.7;">
                    Sample size: {{ execution_quality.trade_count }} trades, {{ execution_quality.rejected_count }} rejections
                </div>
            </div>
        </div>
    </section>
    {% endif %}

    {% if strategic_confluence %}
    {% set ns.count = ns.count + 1 %}
    <section id="strategic-confluence">
        <h2>{{ ns.count }}. Strategic Confluence Analysis</h2>
        <div class="score-container">
            <span>Overall Confluence:</span>
            <div class="progress-bar" role="progressbar" aria-valuenow="{{ strategic_confluence.confluence_score * 100 }}" aria-valuemin="0" aria-valuemax="100">
                <div class="progress-fill {% if strategic_confluence.confluence_score < 0.6 %}fill-low{% elif strategic_confluence.confluence_score < 0.8 %}fill-medium{% else %}fill-high{% endif %}" style="width: {{ strategic_confluence.confluence_score * 100 }}%;"></div>
            </div>
            <span class="score">{{ (strategic_confluence.confluence_score * 100)|round(1) }}%</span>
        </div>

        <div class="grid-2">
            <table>
                <thead>
                    <tr>
                        <th scope="col">Alignment Category</th>
                        <th scope="col">Score</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>Market Regime Alignment</td>
                        <td><strong>{{ (strategic_confluence.regime_alignment * 100)|round(1) }}%</strong></td>
                    </tr>
                    <tr>
                        <td>Trading Session Alignment</td>
                        <td><strong>{{ (strategic_confluence.session_alignment * 100)|round(1) }}%</strong></td>
                    </tr>
                    <tr>
                        <td>Volatility State Alignment</td>
                        <td><strong>{{ (strategic_confluence.volatility_alignment * 100)|round(1) }}%</strong></td>
                    </tr>
                </tbody>
            </table>
            <div class="insight-box">
                <strong>Strategic Insights:</strong><br>
                {{ strategic_confluence.insights }}
            </div>
        </div>
    </section>
    {% endif %}

    {% if methodology %}
    {% set ns.count = ns.count + 1 %}
    <section id="methodology">
        <h2>{{ ns.count }}. Methodology & Audit Trail</h2>
        <div class="grid-2">
            <div>
                <h3>System Information</h3>
                <ul>
                    <li><strong>Data Source:</strong> {{ methodology.data_source }}</li>
                    <li><strong>Backtest Engine:</strong> {{ methodology.backtest_engine }}</li>
                    <li><strong>Lookback Period:</strong> {{ methodology.lookback_period }}</li>
                </ul>
            </div>
            <div>
                <h3>Core Assumptions</h3>
                <ul>
                    {% for assumption in methodology.assumptions %}
                    <li>{{ assumption }}</li>
                    {% endfor %}
                </ul>
            </div>
        </div>
        <h3>Risk Limits Applied</h3>
        <div style="display: flex; flex-wrap: wrap; gap: 10px; margin-top: 10px;">
            {% for limit in methodology.risk_limits %}
            <span class="badge badge-stable" style="background-color: #ebf8ff; color: #2c5282; border: 1px solid #bee3f8;">{{ limit }}</span>
            {% endfor %}
        </div>
    </section>
    {% endif %}

    {% set ns.count = ns.count + 1 %}
    <section id="conclusion">
        <h2>{{ ns.count }}. Conclusion & Recommendations</h2>
        <div style="margin-bottom: 2rem;">
            <h3>Strategic Conclusion</h3>
            <p>{{ conclusion }}</p>
        </div>

        {% if recommendations %}
        <h3>Actionable Recommendations</h3>
        <ul class="recommendation-list">
            {% for rec in recommendations %}
            <li class="recommendation-item">{{ rec }}</li>
            {% endfor %}
        </ul>
        {% endif %}
    </section>
    </main>

    <a href="#" class="back-to-top" title="Back to top" aria-label="Scroll back to top">
        <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="m18 15-6-6-6 6"/></svg>
    </a>

    <script>
        window.addEventListener('scroll', () => {
            const backToTop = document.querySelector('.back-to-top');
            const scrollBar = document.getElementById('scrollBar');

            // Back to top visibility
            if (window.scrollY > 300) {
                backToTop.classList.add('visible');
            } else {
                backToTop.classList.remove('visible');
            }

            // Scroll progress bar
            const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
            const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
            const scrolled = (winScroll / height) * 100;
            if (scrollBar) {
                scrollBar.style.width = scrolled + "%";
            }
        });
    </script>

    <footer>
        &copy; 2024-2025 Triqbit MT5 Research. All rights reserved. Generated by ResearchReporter.
    </footer>
</body>
</html>
